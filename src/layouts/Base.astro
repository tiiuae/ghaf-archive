---
import "../styles/global.css";
import "@fontsource/lato";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="font-mono w-screen flex flex-col min-h-screen justify-between">
    <div>
      <slot />
    </div>
    <footer class="w-screen items-end my-5">
      <p class="text-sm m-auto text-center">
        Copyright 2022-2026 TII (SSRC) and the Ghaf contributors
      </p>
    </footer>
  </body>
</html>
